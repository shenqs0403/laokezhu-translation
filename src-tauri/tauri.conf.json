{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "laokezhu-translation",
  "version": "0.1.0",
  "identifier": "com.github.laokezhu.translation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "hide",
        "visible": false
      },
      {
        "label": "config",
        "width": 400,
        "height": 700,
        "create": false
      },
      {
        "label": "about",
        "width": 400,
        "height": 700,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
